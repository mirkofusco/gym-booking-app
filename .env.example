OPENAI_API_KEY=sk-your-key-here

# Optional: change these only if you want different models.
TRANSCRIBE_MODEL=gpt-4o-transcribe
FALLBACK_TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize
SUMMARY_MODEL=gpt-5.4-nano
TRANSCRIBE_PROMPT=Trascrivi in italiano una visita professionale. Mantieni nomi, misure, alimenti, farmaci e indicazioni cosi' come vengono detti. Non aggiungere commenti.
OPENAI_TIMEOUT_MS=70000
OPENAI_RETRIES=1
PORT=3000

# Optional: send welcome emails when an admin creates a client.
APP_URL=https://recap-ai-frky.onrender.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Recap AI <your@email.com>"
